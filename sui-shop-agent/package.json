{
  "name": "sui-shop-agent",
  "version": "1.0.0",
  "description": "AI Agent for Jimmy's SUI Shop - autonomous purchasing via natural language",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "setup": "tsx src/setup.ts",
    "server": "tsx src/server.ts",
    "web:dev": "concurrently --kill-others --names \"server,vite\" --prefix-colors \"blue,green\" \"tsx --watch src/server.ts\" \"npm run dev --prefix web\"",
    "web:build": "npm run build --prefix web",
    "web": "npm run web:build && tsx src/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@mysten/sui": "latest",
    "@types/nodemailer": "^7.0.11",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "nodemailer": "^8.0.1",
    "readline": "^1.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
